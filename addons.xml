<addons>
<addon id="plugin.program.encore"
       name="My Kodi Build"
       version="1.0.0"
       provider-name="ashcan57">
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Install My Custom Kodi Build</summary>
        <description>This addon installs and sets up My Kodi Build from Dropbox.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
        <source>https://www.dropbox.com/scl/fi/90rsb9oal9dc3fp3g1l8s/dab19.zip?rlkey=5st59x4bq5xpvljnf0rlflu1z&st=mi670jql&dl=1</source>
    </extension>
</addon>

<addon id="repository.encore"
       name="Encore Repository"
       version="1.0.0"
       provider-name="ashcan57">

    <extension point="xbmc.addon.repository" name="Encore Repository">
        <info>https://ashcan57.github.io/repository.encore/addons.xml</info>
        <checksum>https://ashcan57.github.io/repository.encore/addons.xml.md5</checksum>
        <datadir>https://ashcan57.github.io/repository.encore/zips/</datadir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Official Encore Repository</summary>
        <description>Encore repository for builds and addons by ashcan57.</description>
        <platform>all</platform>
    </extension>

</addon>
</addons>
