<addons>
    <addon id="repository.encore"
           name="Encore Repository"
           version="1.0.0"
           provider-name="ashcan57">
        <extension point="xbmc.addon.repository"
                   name="Encore Repository">
            <info>https://ashcan57.github.io/encore/addons.xml</info>
            <checksum>https://ashcan57.github.io/encore/addons.xml.md5</checksum>
            <datadir>https://ashcan57.github.io/encore/</datadir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Encore Repository</summary>
            <description>Official repository for Encore Wizard and builds.</description>
            <platform>all</platform>
        </extension>
    </addon>

    <addon id="plugin.program.encore"
           name="Encore Wizard"
           version="1.0.0"
           provider-name="ashcan57">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>Encore Wizard</summary>
            <description>Install and manage the Encore Kodi build.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>

