<addon id="repository.encore"
       name="My Kodi Repo"
       version="1.0.0"
       provider-name="ashcan57">
    <extension point="xbmc.addon.repository"
               name="My Kodi Repository">
        <info compressed="false">https://raw.githubusercontent.com/ashcan57/encore/main/addons.xml</info>
        <checksum>https://raw.githubusercontent.com/ashcan57/encore/main/addons.xml.md5</checksum>
        <datadir zip="true">https://raw.githubusercontent.com/ashcan57/encore/main/zips/</datadir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>My Kodi Repository</summary>
        <description>Repository for My Kodi Addons and Builds</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>

